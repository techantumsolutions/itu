{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 9999",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov --coverageReporters=json-summary",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "lcr:worker": "tsx --tsconfig tsconfig.json scripts/lcr-sync-worker.ts",
    "cron:provider-sync": "tsx --tsconfig tsconfig.json scripts/provider-sync-cron.ts",
    "system-plans:availability": "tsx --tsconfig tsconfig.json scripts/system-plans-availability-worker.ts",
    "system-plans:merge-duplicates": "tsx --tsconfig tsconfig.json scripts/system-plans-duplicate-merge-worker.ts",
    "bootstrap:admin": "tsx --tsconfig tsconfig.json scripts/bootstrap-super-admin.ts",
    "db:migrate": "tsx --tsconfig tsconfig.json scripts/db-migrate.ts",
    "db:encrypt-credentials": "tsx --tsconfig tsconfig.json scripts/migrate-encrypt-provider-credentials.ts",
    "db:migrate:production": "bash scripts/db-migrate-production.sh",
    "db:bootstrap": "tsx --tsconfig tsconfig.json scripts/db-bootstrap-legacy.ts",
    "db:import-dump": "tsx --tsconfig tsconfig.json scripts/import-international-dump.ts",
