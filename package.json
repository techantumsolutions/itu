    "supabase:reset": "supabase db reset",
    "supabase:sync-env": "tsx --tsconfig tsconfig.json scripts/sync-supabase-env.ts",
    "db:local": "npm run supabase:start && npm run db:bootstrap && npm run db:migrate && npm run supabase:sync-env",
    "dev:stack": "docker compose up -d redis && supabase start",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:detach": "docker compose -f docker-compose.dev.yml up -d --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "deploy:prod": "bash scripts/deploy-prod.sh",
    "deploy:healthcheck": "bash scripts/deploy-healthcheck.sh",
    "deploy:rollback": "bash scripts/deploy-rollback.sh",
    "backup:all": "bash scripts/backup/backup-all.sh",
    "backup:verify": "bash scripts/backup/verify-backup.sh",
    "backup:postgres": "bash scripts/backup/backup-postgres.sh",
    "backup:redis": "bash scripts/backup/backup-redis.sh",
    "backup:volumes": "bash scripts/backup/backup-volumes.sh",
    "backup:storage": "bash scripts/backup/backup-storage.sh",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:smoke": "tsx --tsconfig tsconfig.json scripts/docker-smoke-test.ts",
    "docker:validate:sidecar": "node scripts/docker-sidecar-validate.mjs",
    "docker:audit:sidecar-imports": "node scripts/audit-sidecar-imports.mjs",
    "docker:build:web": "docker build -f Dockerfile -t itu-web:phase3e .",
    "docker:build:sidecar": "docker build -f Dockerfile.sidecar -t itu-sidecar:phase3e .",
    "docker:validate:phase3d": "node scripts/docker-phase3d-validate.mjs",
    "docker:measure:phase3e": "node scripts/docker-phase3e-measure.mjs"
