# Copy to .env and fill in values (never commit .env).

# --- Local Supabase (Docker via Supabase CLI) ---
# 1. Start Docker Desktop
# 2. npm run supabase:start
# 3. npm run db:bootstrap && npm run db:migrate
# 4. npm run supabase:sync-env
# Studio: http://127.0.0.1:54423  |  API: http://127.0.0.1:54421  |  DB port: 54422
# (Ports 54420+ avoid Windows Hyper-V reserved ranges around 54304–54403)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres
SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: verify access tokens locally (HS256) to skip /auth/v1/user RTT. From Supabase JWT secret.
# SUPABASE_JWT_SECRET=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Temporary testing: include OTP in send-OTP API JSON so UI can show it (no email/SMS needed).
# Auto-enabled when NODE_ENV !== production.
# SHOW_DEV_OTP=true
# Production compose forces SHOW_DEV_OTP=false (do not enable in real prod).

# --- Catalog (countries / operators / plans): Supabase Postgres via PostgREST ---
# Legacy schemas: npm run db:bootstrap | incremental: npm run db:migrate

# AES-256-GCM master key for lcr_providers.credentials_encrypted (required in production).
# Generate (any OS with Node): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or: openssl rand -base64 32
# After setting, run once: npm run db:encrypt-credentials
MASTER_ENCRYPTION_KEY=

# Dev only: npm run bootstrap:admin — creates/updates super admin.
# ADMIN_BOOTSTRAP_EMAIL=admin@itu.com
# Required when creating or resetting the super admin (no hardcoded default).
ADMIN_BOOTSTRAP_PASSWORD=

# Redis (optional in local host/dev). If set, enables server-side caching for CMS and catalog.
# Local host dev: redis://127.0.0.1:6379  |  Docker compose: redis://redis:6379
REDIS_URL=
# Process-local L1 Redis cache (default off — safer for multi-replica). Set true only for single instance.
# CACHE_L1_ENABLED=true
# Required for production (docker-compose.prod.yml). Enables Redis requirepass AUTH.
# Generate: openssl rand -base64 32
# Compose sets REDIS_URL=redis://redis:6379 and REDIS_PASSWORD; the app injects AUTH into the URL.
REDIS_PASSWORD=

# --- Backup / DR (ops host; never commit real values) ---
# BACKUP_ROOT=.backups
# BACKUP_RETENTION_DAYS=30
# BACKUP_ENCRYPTION_KEY=   # openssl rand -base64 32 — required to encrypt .env backups
# SUPABASE_STORAGE_VOLUME= # self-hosted Storage Docker volume name (preferred)
# STORAGE_BACKUP_BUCKETS=user_avatars,ticket_attachments
# See docs/BACKUP.md, docs/RESTORE.md, docs/DISASTER_RECOVERY.md, docs/RUNBOOK.md

# --- Docker ---
# Redis only (host Next.js):     npm run dev:stack
# Full dev stack (hot reload):   npm run docker:dev
# Dev web URL (host npm dev stays on :3000): http://localhost:3010
# Dev / prod socket URL:         http://localhost:3001
# Production stack:              npm run docker:prod
# Prod web URL:                  http://localhost:3000
# Smoke test (dev defaults):     npm run docker:smoke
# Smoke test (prod):             npx tsx scripts/docker-smoke-test.ts --web http://localhost:3000 --socket http://localhost:3001
# Health: GET /api/health (live), GET /api/health/ready (Redis + Supabase; not Socket.IO)
# Dev stack expects Supabase on host (host.docker.internal:54421/54422).
# Internal DNS (compose network): redis:6379, web:3000, socket:3001
#
# Prod stack (docker-compose.prod.yml) joins external network supabase_network_itu and
# overrides SUPABASE_URL to Kong's Docker DNS: http://supabase_kong_itu:8000
# (host .env may keep SUPABASE_URL=http://127.0.0.1:54421 for host-side tools).
# Keep NEXT_PUBLIC_SUPABASE_URL as the browser-reachable host URL (e.g. :54421).
# Prerequisite: `npm run supabase:start` so supabase_network_itu + supabase_kong_itu exist.
#
# Split images (Phase 3D/3E — docker-compose.prod.yml):
#   web     → Dockerfile (Next standalone + BuildKit pnpm cache)
#   sidecars → Dockerfile.sidecar (BuildKit pnpm cache)
#   pnpm docker:build:web
#   pnpm docker:build:sidecar
#   pnpm docker:validate:phase3d
#   pnpm docker:measure:phase3e
#   pnpm docker:audit:sidecar-imports
#
# --- Docker build-args (prod Dockerfile; fail-closed if required missing) ---
# Verified against static process.env / next.config usage only.
#   NEXT_PUBLIC_APP_URL              BUILD + RUNTIME — bake for static embeds
#                                    (jobs email HTML, recaptcha hostname); keep in
#                                    runtime env for runtimeEnv() server reads (audit emails).
#   NEXT_PUBLIC_SUPABASE_URL         BUILD + RUNTIME — bake for next.config CSP; keep at
#                                    runtime for headers helpers / client consistency.
#   NEXT_PUBLIC_RECAPTCHA_ENABLED    BUILD (+ runtime match) — static client/server flag;
#                                    changing requires image rebuild.
#   NEXT_PUBLIC_RECAPTCHA_SITE_KEY   BUILD when enabled=true (+ runtime match); client embed.
# NOT a Docker build-arg (dynamic runtimeEnv / unused in bundle):
#   NEXT_PUBLIC_SOCKET_SERVER_URL    RUNTIME — compose/env_file. Client ticket pages use
#                                    getPublicSocketServerUrl() via runtimeEnv (dynamic), so
#                                    browser falls back to window.location + SOCKET_PORT.
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY  RUNTIME/docs (sync-supabase-env only; not in app bundle).

# Optional cache purge secret (required in production for POST /api/cache/purge)
CACHE_PURGE_SECRET=

# Cron auth for protected /api/cron/* endpoints (required in production)
CRON_SECRET=

# Legacy payment webhook auth (required in production for POST /api/payment/webhook)
PAYMENT_WEBHOOK_SECRET=

# HMAC secret used to sign the OTP/guest session cookie (itu-user-id).
# REQUIRED in production — the app fails fast if missing. In development a
# documented insecure fallback is used when this is unset.
OTP_SESSION_SECRET=

# Dev only: allow x-user-id header fallback when cookies are unavailable (never enable in production)
# ALLOW_INSECURE_USER_HEADERS=true

# Unpaid / anonymous provider execution is forbidden.
# POST /api/recharge: (A) paid checkout with transactionId, or (B) admin with providers.execute.
# RECHARGE_PUBLIC_ENABLED has been removed and is never read.

# Background provider auto-sync scheduler (local/VM process):
# - Run with: npm run cron:provider-sync
# - Calls POST /api/cron/lcr-v2-sync every 24h by default
CRON_PROVIDER_SYNC_BASE_URL=http://127.0.0.1:3000
CRON_PROVIDER_SYNC_INTERVAL_HOURS=24
# Set false to skip the immediate run at startup
CRON_PROVIDER_SYNC_RUN_ON_START=true

# --- DT One (LCR ingestion, /api/dtone/products, LCR v2) ---
# Required for bootstrap + sync when no credentials are stored on the provider row.
# DTONE_BASE_URL is optional; defaults to https://prepaid.dtone.com
DTONE_API_KEY=
DTONE_API_SECRET=
# DTONE_BASE_URL=

# --- Value Topup (IIMMPACT-compatible /api/v2; catalog sync + LCR v2 recharge) ---
# HMAC secret is Base64-encoded (from Value Topup dashboard → API Keys).
VALUE_TOPUP_API_KEY=
VALUE_TOPUP_HMAC_SECRET=
# Sandbox default: https://sandbox.valuetopup.com/api/v2
VALUE_TOPUP_BASE_URL=
# VALUE_TOPUP_PROD_BASE_URL=https://www.valuetopup.com/api/v2

# --- App URL (Supabase Auth redirects + email links) ---
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Set COOKIE_SECURE=false when the site is served over plain HTTP (e.g. IP:port without TLS).
# Otherwise login cookies are Secure-only and the server cannot read user id during checkout.
# COOKIE_SECURE=false

# Inactivity timeout (minutes) for customer, admin staff, and super-admin sessions.
# Also used for admin page-password section lock after inactivity. Default: 20.
SESSION_IDLE_TIMEOUT_MINUTES=20

# --- Support ticket live updates (Socket.io) ---
# Server process: npm run socket:server  (or pm2 start "pnpm socket:server" --name itu-socket)
# Next.js API → socket broadcast (same machine):
SOCKET_SERVER_URL=http://127.0.0.1:3001
SOCKET_PORT=3001
SOCKET_HOST=127.0.0.1
SOCKET_BIND_HOST=0.0.0.0
# Browser clients: runtime env (not a Docker build-arg — see Docker build-args notes above).
# Client code reads via runtimeEnv (dynamic); falls back to window.location + SOCKET_PORT.
NEXT_PUBLIC_SOCKET_SERVER_URL=http://127.0.0.1:3001
# Set to true to skip broadcast calls when socket server is not used
# SOCKET_SERVER_DISABLED=true
# Shared secret authenticating Next.js API -> socket server POST /api/broadcast.
# REQUIRED in production (broadcasts fail closed if missing); dev uses a documented fallback.
# Must be identical for the web and socket services.
SOCKET_BROADCAST_SECRET=

# --- SMTP (Next.js nodemailer + local Supabase Auth via supabase/config.toml) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# When true, Supabase Auth skips email confirmation (enable_confirmations=false in config.toml)
ENABLE_EMAIL_AUTOCONFIRM=true

# --- Google reCAPTCHA v2 (authentication forms) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Set true only when reCAPTCHA should be enforced (default off)
NEXT_PUBLIC_RECAPTCHA_ENABLED=false

DING_API_BASE_URL=https://api.dingconnect.com
DING_API_KEY=
DING_CLIENT_ID=
DING_CLIENT_SECRET=

# --- Observability (see docs/OBSERVABILITY.md) ---
# LOG_FORMAT=json
# LOG_LEVEL=info
# SERVICE_NAME=itu-web
# APP_ENV=production
# APP_VERSION=
# METRICS_TOKEN=          # required for non-loopback /api/metrics scrapes
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
