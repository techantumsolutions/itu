FROM node:22-alpine

RUN apk add --no-cache libc6-compat procps wget

WORKDIR /app

COPY package.json package-lock.json* ./

RUN npm ci

ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0

EXPOSE 3000 3001

# Source is bind-mounted in docker-compose.dev.yml for hot reload.
CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0"]
